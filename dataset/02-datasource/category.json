{
    "version": "1.0",
    "updated": "2025-10-20",
    "domain": "metagenomics",
    "global_exclude_regex": [
        "\b(job|hiring|position|salary|resume|cv)\b",
        "\b(course|homework|assignment)\b",
        "\b(non[- ]?bio|metaverse)\b"
    ],
    "categories": [
        {
            "name": "QC",
            "description": "Quality control, trimming, filtering, host read removal, read stats",
            "include_regex_any": [
                "\bfastq[cx]?\b",
                "\bmultiqc\b",
                "\\b(trimmomatic|cutadapt|fastp)\b",
                "\bprinseq\b",
    "\b(adapter|adaptor)\\b*(trim|remov)",
    "\bquality\\b*(filter|trim|score|threshold|phred)\b",
    "\bphred\\b*(20|30|33)\b",
    "\b(per[- ]?base|per[- ]?tile)\\b*quality\b",
                "\b(low[- ]?complexity|duplicate reads?)\b",
    "\b(read\\b*stats?|summary)\b",
    "\b(host\\b*(deplet|remov|filter)|dehost)\b",
    "\b(knead\\b*data|kneaddata)\b",
                "\bbbduk|bbmap\b",
                "\b(sickle|skewer)\b",
    "\b(human|host)\\b*(read|contamination)\b"
            ],
            "tags": [
                "qc",
                "trimming",
                "filtering",
                "host-removal"
            ]
        },
        {
            "name": "Sequencing & Data Types",
            "description": "Shotgun vs amplicon, read lengths, platforms",
            "include_regex_any": [
    "\bshotgun\\b+metagenom",
                "\b(16s|18s|its)\b",
                "\bpaired[- ]?end\b",
                "\b(single[- ]?end|SE)\b",
                "\b(2x150|2x250|150bp|250bp)\b",
                "\billumina\b",
    "\boxford\\b+nanopore|\bONT\b|\bminion|promethion\b",
    "\bpacbio(\\b*hi?fi)?\b",
                "\blong[- ]?read(s)?\b",
                "\bshort[- ]?read(s)?\b",
                "\bamplicon\b",
                "\bmetatranscriptom|metaproteom\b"
            ],
            "tags": [
                "data-type",
                "platform"
            ]
        },
        {
            "name": "Assembly",
            "description": "De novo assembly of metagenomes",
            "include_regex_any": [
                "\bmegahit\b",
                "\bmeta?spades\b",
                "\bflye\b",
                "\bray[- ]?meta\b",
                "\bidba[- ]?ud\b",
                "\b(opera[- ]?ms|metaVelvet)\b",
                "\b(contig|scaffold)s?\b",
                "\bN50|L50\b",
                "\bk[- ]?mer(s)?\b",
                "\bcoverage\b",
    "\bassembly\\b*(graph|stats|parameter|k[- ]?mer)\b",
                "\bco[- ]?assembly|coassembly\b",
    "\bhybrid\\b*assembly\b",
                "\bpolish(ing)?\b",
                "\b(racon|medaka|pilon)\b"
            ],
            "tags": [
                "assembly"
            ]
        },
        {
            "name": "Binning",
            "description": "Genome binning, MAG curation, quality checks",
            "include_regex_any": [
                "\bmetabat2?\b",
                "\bmaxbin\b",
                "\bconcoct\b",
                "\bvamb\b",
                "\bsemibin\b",
                "\b(das[- ]?tool|DASTool)\b",
    "\b(bin\\w*|binning)\b",
                "\bMAGs?\b",
                "\bcheckm(2)?\b",
                "\b(gunc|busco)\b",
                "\bcompletenes?s\b",
                "\bcontamina(ted|tion)\b",
                "\brefinem\b",
                "\bmetaWRAP\b",
    "\b(granulated|differential)\\b+coverage\b"
            ],
            "tags": [
                "binning",
                "mags"
            ]
        },
        {
            "name": "Taxonomy/Profiling",
            "description": "Taxonomic profiling and classification",
            "include_regex_any": [
                "\bkraken2?\b",
                "\bbracken\b",
                "\bcentrifuge\b",
                "\bkaiju\b",
                "\bmOTUs?\b",
                "\bmetaphlan\b",
                "\bclark\b",
    "\bdiamond\\b*blast[xn]?\b",
                "\bgtdb[- ]?tk\b",
                "\bgtdb\b",
    "\bmarker\\b*(gene|based)\b",
    "\bk[- ]?mer\\b*(classifier|based)\b",
    "\btax(on|onomy|onomic)\\b*(assign|profil|classif)\b",
                "\bphylo?gen(etic|y)\b",
    "\b(read|contig)\\b*classification\b"
            ],
            "tags": [
                "taxonomy",
                "profiling"
            ]
        },
        {
            "name": "Functional Profiling",
            "description": "Gene family and pathway profiling from metagenomes",
            "include_regex_any": [
                "\bhumann3?\b",
    "\bshotgun\\b+functional\\b+profil",
    "\b(pathway|module|reaction)\\b+(abundance|coverage)\b",
                "\b(ec|enzyme|kegg|ko)\b",
                "\b(eggNOG|eggno[g|k])\b",
                "\buniref(50|90|100)?\b",
                "\binterpro(scan)?\b",
                "\bghostkoala\b",
                "\bprokka\b",
                "\bDRAM\b",
                "\bmetacyc\b",
    "\bannotation\\b*(pipeline|db)\b"
            ],
            "tags": [
                "functional"
            ]
        },
        {
            "name": "Contamination & Decontamination",
            "description": "Kitome, cross-talk, human reads, index hopping",
            "include_regex_any": [
                "\b(contaminant|contamination|decontamina?tion)\b",
                "\bkitome\b",
    "\bindex\\b*hopping\b",
                "\bbleed[- ]?through|cross[- ]?talk\b",
                "\bdecontam\b",
                "\b(blank controls?|negative controls?)\b",
    "\b(human|host)\\b*(deplet|remov|filter)\b",
    "\bERCC\\b*spike[- ]?ins?\b",
                "\bPhiX\b",
                "\bchimera(s| checking)?\b",
    "\b(kraken|bowtie2|bwa)\\b*(screen|filter)\b"
            ],
            "tags": [
                "contamination"
            ]
        },
        {
            "name": "Statistics & Diversity",
            "description": "Alpha/beta diversity, differential abundance, compositionality",
            "include_regex_any": [
    "\balpha\\b+diversity\b",
    "\bbeta\\b+diversity\b",
                "\brarefaction\b",
                "\b(ordination|PCoA|NMDS)\b",
                "\b(permanova|adonis)\b",
                "\bcompositional(it(y|ies))?\b",
                "\balr|clr|ilr\b",
    "\bancom(\\b*II)?\b",
                "\b(de[- ]?seq2|edgeR|limma)\b",
                "\b(lefse|songbird|aldex2)\b",
                "\b(sparCC|SPIEC[- ]?EASI)\b",
    "\bmultip(le)?\\b*testing|FDR\b"
            ],
            "tags": [
                "statistics",
                "diversity",
                "differential-abundance"
            ]
        },
        {
            "name": "Amplicon-specific (16S/18S/ITS)",
            "description": "OTU/ASV pipelines and tools",
            "include_regex_any": [
                "\b(dada2|deblur)\b",
                "\b(OTU|ASV)s?\b",
                "\bchimera(s| checking)?\b",
                "\bsilva\b",
                "\bgreengenes(2)?\b",
                "\bUNITE\b",
                "\bphyloseq\b",
                "\bmothur\b",
    "\bqiime\\b?2?\b",
    "\b(denois|cluster)\\w*\b"
            ],
            "tags": [
                "amplicon"
            ]
        },
        {
            "name": "Long-read Specific",
            "description": "ONT/PacBio metagenomics handling and polishing",
            "include_regex_any": [
                "\b(basecall(ing)?|guppy|dorado)\b",
                "\b(qscore|read accuracy)\b",
                "\bmedaka|racon|trycycler\b",
                "\b(hifi|ccs)\b",
                "\bchopper|pycoQC\b",
                "\b(long[- ]?read)\b"
            ],
            "tags": [
                "long-read"
            ]
        },
        {
            "name": "Resistome & Virulome",
            "description": "Antibiotic resistance genes and virulence profiling",
            "include_regex_any": [
                "\bresistome\b",
                "\bcard\b",
                "\bar(g|gs)\b",
                "\b(amr|antimicrobial resistance)\b",
                "\b(vfdb|virulence)\b",
                "\babricate\b",
                "\bdeepARG\b",
                "\bRGI\b"
            ],
            "tags": [
                "resistome",
                "virulome"
            ]
        },
        {
            "name": "Viromics",
            "description": "Viral metagenomics discovery and profiling",
            "include_regex_any": [
    "\bvir(al|us)\\b+metagenom",
                "\b(vibrant|virsorter2?|checkv)\b",
                "\bvirfinder\b",
                "\b(phage|prophage)\b",
                "\bcrAssphage\b",
    "\bviral\\b*contigs?\b"
            ],
            "tags": [
                "viromics"
            ]
        },
        {
            "name": "Strain-level & Pangenomes",
            "description": "Strain resolution, SNPs, pan-genome analysis",
            "include_regex_any": [
                "\bstrainphlan\b",
                "\bDESMAN\b",
                "\bMIDAS(2)?\b",
    "\bstrains?\\b*(track|resolut|profil)\b",
                "\bSNPs?\b",
                "\bpangenom(e|ics)\b",
                "\b(roary|panaroo|anvio)\b"
            ],
            "tags": [
                "strain",
                "pangenome"
            ]
        },
        {
            "name": "Databases",
            "description": "Reference databases frequently used in metagenomics",
            "include_regex_any": [
                "\b(SILVA|Greengenes2?|RDP)\b",
                "\b(GTDB|GTDB[- ]?Tk)\b",
                "\b(RefSeq|GenBank)\b",
    "\b(MetaPhlAn|mOTUs)\\b*db\b",
                "\b(KEGG|KO|eggNOG|UniRef|MetaCyc)\b",
                "\b(HO?MAG|UHGG|UHGP)\b",
                "\b(CARD|VFDB)\b",
                "\b(COG|PFAM|TIGRFAM)\b"
            ],
            "tags": [
                "databases"
            ]
        },
        {
            "name": "Workflow & Orchestration",
            "description": "Pipelines, workflow engines, containers, reproducibility",
            "include_regex_any": [
                "\b(nextflow|snakemake|cromwell|wdl|nf[- ]?core)\b",
                "\b(docker|singularity|apptainer|conda|mamba)\b",
                "\bpipeline(s)?\b",
                "\b(anvio|sunbeam|metaWRAP|ATLAS)\b",
    "\b(workflow\\b*(design|best\\b*practic))\b"
            ],
            "tags": [
                "workflow",
                "orchestration",
                "reproducibility"
            ]
        },
        {
            "name": "Mapping & Alignment",
            "description": "Read mapping to references, host or microbe",
            "include_regex_any": [
                "\bbowtie2?\b",
                "\bbwa(-mem2?)?\b",
                "\bminimap2\b",
                "\bsamtools\b",
    "\b(read\\b*mapping|alignment)\b",
    "\bmapping\\b*rate\b",
    "\bhost\\b*(mapping|filter)\b"
            ],
            "tags": [
                "mapping"
            ]
        },
        {
            "name": "File Formats & Utilities",
            "description": "Common file formats and manipulation tools",
            "include_regex_any": [
                "\b(fastq|fasta|bam|sam|cram|gff3?|gtf|bed)\b",
                "\b(seqkit|seqtk|bbtools)\b",
                "\bgzip|bgzip|tabix\b",
    "\bkraken\\b*report|bracken\\b*report\b",
                "\bbiom\b"
            ],
            "tags": [
                "formats",
                "utilities"
            ]
        },
        {
            "name": "Benchmarking & Evaluation",
            "description": "Tool comparison, mock communities, metrics",
            "include_regex_any": [
    "\b(mock\\b*community|simulated\\b*reads?)\b",
                "\bprecision|recall|f1[- ]?score\b",
                "\bAUROC|AUPR\b",
                "\bCAMI\b",
    "\b(hallucination|false\\b*positives?)\b",
                "\b(runtime|memory|CPU)\b",
                "\bbenchmark(ing)?\b"
            ],
            "tags": [
                "benchmarking",
                "evaluation"
            ]
        },
        {
            "name": "Sample Prep & Experimental Design",
            "description": "Extraction, library prep, depth estimation, contamination controls",
            "include_regex_any": [
    "\bDNA\\b*(extraction|yield)\b",
    "\blibrary\\b*(prep|preparation)\b",
    "\bfragment\\b*size\b",
    "\b(read|sequencing)\\b*depth\b",
    "\b(batch\\b*effects?)\b",
    "\bnegative\\b*controls?|blanks?\b",
    "\b(host|human)\\b*blocking\b"
            ],
            "tags": [
                "experiment",
                "design"
            ]
        },
        {
            "name": "Visualization & Reporting",
            "description": "Common plotting and report artifacts for metagenomics",
            "include_regex_any": [
    "\btaxonomic\\b*barplot\b",
                "\bheatmap\b",
    "\btree\\b*(phylo|newick)\b",
                "\bSankey\b",
                "\bKrona\b",
                "\breport(ing)?\b"
            ],
            "tags": [
                "visualization",
                "reporting"
            ]
        }
    ],
